#include "am13e.dtsi"

/ {
	#address-cells = <1>;
	#size-cells = <1>;

	soc {
		sram0_1_2: memory@20000000 {
			compatible = "zephyr,memory-region";
			reg = <0x20000000 DT_SIZE_K(96)>;
			zephyr,memory-region = "SRAM012";
		};

		sram3_cahb: memory@c18000 {
			compatible = "zephyr,memory-region";
			reg = <0xC18000 DT_SIZE_K(32)>;
			zephyr,memory-region = "SRAM3CAHB";
		};

		sram3_sahb: memory@20018000 {
			compatible = "zephyr,memory-region";
			reg = <0x20018000 DT_SIZE_K(32)>;
			zephyr,memory-region = "SRAM3SAHB";
		};

		pinctrl: pin-controller@400cc000 {
			compatible = "ti,msp-pinctrl";
			reg = <0x400cc000 DT_SIZE_K(16)>;
		};

		gpio0: gpio@400f0000 {
			compatible = "ti,msp-gpio";
			reg = <0x400f0000 DT_SIZE_K(8)>;
			interrupts = <4 0>;
			#gpio-cells = <2>;
			gpio-controller;
		};

		gpio1: gpio@400f2000 {
			compatible = "ti,msp-gpio";
			reg = <0x400f2000 DT_SIZE_K(8)>;
			interrupts = <5 0>;
			#gpio-cells = <2>;
			gpio-controller;
		};

		gpio2: gpio@400f4000 {
			compatible = "ti,msp-gpio";
			reg = <0x400f4000 DT_SIZE_K(8)>;
			interrupts = <6 0>;
			#gpio-cells = <2>;
			gpio-controller;
		};

		gpio3: gpio@400f6000 {
			compatible = "ti,msp-gpio";
			reg = <0x400f6000 DT_SIZE_K(8)>;
			interrupts = <7 0>;
			#gpio-cells = <2>;
			gpio-controller;
		};
	};
};

&nvic {
	arm,num-irq-priority-bits = <4>;
};

/ {
	chosen {
		/* Define shared memory region for RPMsg */
		zephyr,ipc_shm = &rpmsg_shm;
		zephyr,ipc = &ipc0;
	};
};

/* Enable mailbox used for notifications */
&mailbox0 {
	status = "okay";
};

&ipc0 {
	role = "host";
	status = "okay";
};
